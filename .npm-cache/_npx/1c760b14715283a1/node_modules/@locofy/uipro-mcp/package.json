{
  "name": "@locofy/uipro-mcp",
  "version": "1.1.3",
  "description": "UIPro MCP by Locofy.ai",
  "keywords": [
    "figma",
    "uipro",
    "locofy",
    "mcp",
    "design-system"
  ],
  "homepage": "https://github.com/Locofy/uipro-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/Locofy/uipro-mcp.git"
  },
  "license": "MIT",
  "author": "Locofy",
  "main": "./src/index.ts",
  "type": "module",
  "scripts": {
    "build": "rm -rf build && tsc && node -e \"const fs=require('fs');const f='build/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f));fs.chmodSync(f,'755')\" && find build -name '*.js' -exec npx terser {} --compress drop_console=true --output {} \\;",
    "dev": "tsx src/index.ts",
    "link": "npm run build && npm link",
    "unlink": "npm unlink -g @locofy/uipro-mcp",
    "start": "npm run build && node build/index.js",
    "lint": "eslint . --ext .ts --fix --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.ts\"",
    "test": "NODE_ENV=test jest --coverage --coverageReporters=text-summary --detectOpenHandles --forceExit"
  },
  "bin": {
    "uipro-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.1",
    "jimp": "^0.22.12",
    "svg2vectordrawable": "^2.9.1",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "@types/uuid": "^9.0.6",
    "@types/ws": "^8.5.8",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "terser": "^5.39.0",
    "ts-jest": "^29.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  }
}
